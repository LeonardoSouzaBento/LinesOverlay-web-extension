{
  "manifest_version": 3,
  "name": "UI Ruler",
  "version": "1.0.0",
  "description": "Overlay de linhas guia para desenvolvimento",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "./logo.png",
    "32": "./logo.png",
    "48": "./logo.png",
    "128": "./logo.png"
  },
  "action": {
    "default_icon": "./logo.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
